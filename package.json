{
  "name": "pp-web-sdk",
  "version": "2.0.1",
  "description": "Modular web SDK for analytics, attribution, login detection, event tracking, and more",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "build": "npm run typecheck && node build.js",
    "build:watch": "node build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "analytics",
    "mixpanel",
    "ga4",
    "attribution",
    "tracking"
  ],
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.24.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
